{
  "expo": {
    "name": "زعفران",
    "slug": "zafaran-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zafaranapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0500"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zafaran.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج موقعك لتوصيل طلبك بدقة",
        "NSLocationAlwaysUsageDescription": "نحتاج موقعك لتوصيل طلبك بدقة",
        "NSPhotoLibraryUsageDescription": "نحتاج الوصول للصور حتى تتمكن من رفع صور الوجبات",
        "NSCameraUsageDescription": "نحتاج الكاميرا حتى تتمكن من تصوير ورفع صور الوجبات"
      }
    },
    "android": {
      "package": "com.zafaran.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0500"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0A0500"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج موقعك لتوصيل طلبك بدقة"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول للصور حتى تتمكن من رفع صور الوجبات",
          "cameraPermission": "نحتاج الكاميرا حتى تتمكن من تصوير ورفع صور الوجبات"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4afa0fbf-0d21-4926-b6dd-fe7706254776"
      }
    },
    "owner": "medo0503"
  }
}